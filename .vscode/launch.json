{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Flask Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Launch Mobile (Internal)",
            "type": "editor-browser",
            "request": "launch",
            "url": "http://127.0.0.1:5000/?preview=mobile#mobile-preview",
            "presentation": {
                "group": "responsive"
            }
        },
        {
            "name": "Launch Tablet (Internal)",
            "type": "editor-browser",
            "request": "launch",
            "url": "http://127.0.0.1:5000/?preview=tablet#tablet-preview",
            "presentation": {
                "group": "responsive"
            }
        }
    ],
    "compounds": [
        {
            "name": "Run Flask + Mobile (Internal)",
            "configurations": [
                "Run Flask Server",
                "Launch Mobile (Internal)"
            ]
        },
        {
            "name": "Run Flask + Tablet (Internal)",
            "configurations": [
                "Run Flask Server",
                "Launch Tablet (Internal)"
            ]
        }
    ]
}